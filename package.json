{
  "name": "wells-fargo-tecopos",
  "version": "1.0.0",
  "description": "Monorepo de Microservicios",
  "private": true,
  "scripts": {
    "start:all": "npx concurrently -n \"GATEWAY,SSO,FINANCE\" -c \"magenta,blue,green\" \"cd apps/api-gateway && npm run start:dev\" \"cd apps/sso-service && npm run start:dev\" \"cd apps/finance-service && npm run start:dev\"",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "nest start"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "axios": "^1.14.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "kafkajs": "^2.2.4",
    "passport-jwt": "^4.0.1",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "concurrently": "^8.2.0",
    "typescript": "^5.0.0"
  }
}